<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Editar Gasto</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: #f6f7fb;
      font-family: Arial, sans-serif;
    }

    .card {
      border: none;
      border-radius: 18px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.08);
      padding: 30px;
    }

    .btn-success {
      background: #6c5ce7;
      border: none;
    }

    .btn-success:hover {
      background: #5a4bd6;
    }

    .btn-secondary {
      border-radius: 10px;
    }

    input, select {
      border-radius: 10px !important;
      margin-bottom: 12px;
    }

    h2 {
      font-weight: 700;
    }
  </style>
</head>

<body>

<div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">

  <div class="card w-100" style="max-width: 500px;">

    <h2 class="mb-4 text-center">Editar Gasto</h2>

    <!-- WARNING -->
    <% if (query && query.error) { %>
      <div class="alert alert-warning">
        ⚠️ No puedes guardar un gasto vacío
      </div>
    <% } %>

    <form action="/update-expense/<%= expense.id %>" method="POST">

      <input class="form-control" type="text" name="title" value="<%= expense.title %>" required>

      <input class="form-control" type="number" name="amount" value="<%= expense.amount %>" required>

      <select class="form-control" name="category" required>
        <option value="comida" <%= expense.category === 'comida' ? 'selected' : '' %>>Comida</option>
        <option value="transporte" <%= expense.category === 'transporte' ? 'selected' : '' %>>Transporte</option>
        <option value="ocio" <%= expense.category === 'ocio' ? 'selected' : '' %>>Ocio</option>
        <option value="otros" <%= expense.category === 'otros' ? 'selected' : '' %>>Otros</option>
      </select>

      <input class="form-control" type="date" name="expense_date" value="<%= expense.expense_date %>" required>

      <button class="btn btn-success w-100 mt-2">
        Guardar cambios
      </button>

      <a href="/dashboard" class="btn btn-secondary w-100 mt-2">
        Cancelar
      </a>

    </form>

  </div>

</div>

</body>
</html>