<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Editar Gasto</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<div class="container mt-5">

  <h2 class="mb-4">Editar Gasto ✏️</h2>

  <form action="/update-expense/<%= expense.id %>" method="POST">

    <input class="form-control mb-2" type="text" name="title" value="<%= expense.title %>" required>

    <input class="form-control mb-2" type="number" name="amount" value="<%= expense.amount %>" required>

    <input class="form-control mb-2" type="text" name="category" value="<%= expense.category %>">

    <input class="form-control mb-2" type="date" name="expense_date" value="<%= expense.expense_date %>">

    <button class="btn btn-success">
      Guardar cambios
    </button>

    <a href="/dashboard" class="btn btn-secondary">
      Cancelar
    </a>

  </form>

</div>

</body>
</html>